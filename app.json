{
  "expo": {
    "name": "UNQX",
    "slug": "unqx-app",
    "scheme": "unqxapp",
    "version": "1.0.29",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "bundleIdentifier": "uz.unqx.app",
      "supportsTablet": false,
      "buildNumber": "29",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NFCReaderUsageDescription": "UNQX использует NFC для чтения меток других пользователей, записи вашей ссылки unqx.uz/SLUG и проверки состояния тега.",
        "NSCameraUsageDescription": "Камера нужна только для сканирования QR-кодов цифровых визиток UNQX.",
        "NSPhotoLibraryUsageDescription": "Доступ к фото нужен, чтобы выбрать и загрузить аватар вашей визитки.",
        "NSPhotoLibraryAddUsageDescription": "UNQX сохраняет ваш фирменный QR-код в галерею для офлайн-обмена.",
        "NSFaceIDUsageDescription": "Face ID используется для быстрой и безопасной разблокировки вашего профиля UNQX.",
        "NSUserNotificationsUsageDescription": "UNQX отправляет уведомления о новых тапах визитки и обновлениях статуса заказа.",
        "UNQXPrivacyPolicyURL": "https://unqx.uz/privacy",
        "UNQXTermsOfServiceURL": "https://unqx.uz/terms"
      }
    },
    "android": {
      "icon": "./assets/brand/title.png",
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/brand/title.png",
        "monochromeImage": "./assets/brand/title-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.NFC",
        "android.permission.INTERNET",
        "android.permission.CAMERA",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.VIBRATE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ],
      "googleServicesFile": "./google-services.json",
      "versionCode": 14,
      "package": "uz.unqx.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "react-native-nfc-manager",
        {
          "includeNdefEntitlement": false
        }
      ],
      "./plugins/with-ios-nfc-tag-only",
      "expo-secure-store",
      "expo-local-authentication",
      "expo-notifications",
      [
        "@sentry/react-native/expo",
        {
          "organization": "unqx",
          "project": "unqx"
        }
      ],
      "expo-sharing"
    ],
    "extra": {
      "legal": {
        "privacyPolicyUrl": "https://unqx.uz/privacy",
        "termsOfServiceUrl": "https://unqx.uz/terms",
        "refundPolicyUrl": "https://unqx.uz/refund"
      },
      "router": {},
      "eas": {
        "projectId": "6452d5a7-a420-40da-99ac-dd3b97e86016"
      }
    },
    "owner": "umidyul"
  }
}
